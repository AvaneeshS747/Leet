class Solution:
    def sumRootToLeaf(self, root: Optional[TreeNode]) -> int:
        def dfs(node,cv):
            if not node:       
                return 0
            cv = cv * 2 + node.val
            if not node.left and not node.right:
                return cv
            return dfs(node.left, cv) + dfs(node.right, cv)
    
        return dfs(root, 0)
