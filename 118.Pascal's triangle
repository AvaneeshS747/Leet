class Solution:
    def generate(self, numRows: int) -> List[List[int]]:
        li=[]
        for i in range(numRows):
            row = [0]*(i+1)
            li.append(row)
        for i in range(numRows):
            for j in range(i+1):
                if (j==0) or (j==i):
                    li[i][j]=1
                else:
                    li[i][j]= li[i-1][j-1] +li[i-1][j]
        return li
        
