class Solution:
    def longestCommonPrefix(self, strs: List[str]) -> str:
        m=float("inf")
        for i in range (1,len(strs)):
            count=0
            for j in range (min(len(strs[0]),len(strs[i]))):
                if strs[i][j]==strs[0][j]:
                    count+=1
            m=min(count,m)
        return strs[0][:m]

                
        
