class Solution:
    def setZeroes(self, matrix: List[List[int]]) -> None:
        li = []
        for i in range(len(matrix)):
            for j in range(len(matrix[0])):
                if matrix[i][j]==0:
                    li.append((i,j))
        for i in li:
            for j in range(len(matrix[0])):
                matrix[i[0]][j]=0
            for p in range(len(matrix)):
                for q in range(len(matrix[0])):
                    matrix[p][i[1]]=0
