class Solution:
    def maxProfit(self, prices: List[int]) -> int:
        minp=float("inf")
        maxp=0
        maxprofit=0
        for i in prices:
            if i<minp:
                minp=i
                maxp=0
            elif i>maxp:
                maxp=i
                if maxprofit<maxp-minp:
                    maxprofit=maxp-minp
        return maxprofit



        
